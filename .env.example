# Hashrate.no API key (sign up at https://hashrate.no/account)
HASHRATE_NO_API_KEY=your_api_key_here

# PowerPool observer key (found in PowerPool dashboard Settings)
POWERPOOL_OBSERVER_KEY=your_observer_key_here

# Dashboard auth (leave DASHBOARD_PASSWORD blank to disable auth)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
